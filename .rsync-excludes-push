# ===========================================
# RSYNC EXCLUDES FOR: make push (Local → HA)
# MORE RESTRICTIVE - Protect HA's runtime state!
# ===========================================

# Database and log files
home-assistant_v2.db*
*.db-shm
*.db-wal
*.log*

# Custom add-ons and themes (managed separately)
custom_components/
custom_icons/
themes/

# Runtime/cache directories
.cloud/
deps/
tts/
.uuid
__pycache__/

# HA runtime state files (must not push back)
.HA_VERSION
.ha_run.lock
zigbee.db

# Large directories not needed for config management
backups/
image/
tmp_backups/
www/

# MQTT bridge to TeslaMate — don't push this from the repo. The live config the
# Mosquitto add-on reads is /share/mosquitto/teslamate-bridge.conf (outside
# HA_REMOTE_PATH), set by hand on the host with the real password. Excluding it
# here keeps a stray local copy from ever landing in HA's /config tree.
mosquitto/teslamate-bridge.conf

# Temporary files
*.tmp
*.temp

# ===========================================
# CRITICAL: NEVER PUSH .storage/ TO HA
# These contain runtime state that HA manages:
# - Integration configs (Shelly, Tuya, etc.)
# - Entity/device registries (renames, disables)
# - Dashboards created via UI
# - Authentication and sessions
# All changes should be made via HA UI or API
# ===========================================
.storage/
