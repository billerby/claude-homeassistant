      "description": "Datasource that holds HA-published metrics (typically named 'Prometheus' but pointing at VictoriaMetrics)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
