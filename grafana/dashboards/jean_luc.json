{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Renault 5 E-Tech telemetry, queried via PromQL from VictoriaMetrics (HA entities written as `{entity_id}_value` metrics). Phase 1: SoC, range, available energy, mileage, charging power, temperatures, degradation.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 20},
              {"color": "yellow", "value": 40},
              {"color": "green", "value": 60}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"sensor.jean_luc_battery_value\"}",
          "refId": "A"
        }
      ],
      "title": "Battery SoC",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "green", "value": 200}
            ]
          },
          "unit": "lengthkm"
        }
      },
      "gridPos": {"h": 5, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"sensor.jean_luc_battery_autonomy_value\"}",
          "refId": "A"
        }
      ],
      "title": "Estimated Range",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "lengthkm",
          "decimals": 0
        }
      },
      "gridPos": {"h": 5, "w": 4, "x": 8, "y": 0},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"sensor.jean_luc_mileage_value\"}",
          "refId": "A"
        }
      ],
      "title": "Odometer",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "dark-blue", "index": 0, "text": "Unplugged"}}, "type": "value"},
            {"options": {"1": {"color": "green", "index": 1, "text": "Plugged in"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "transparent", "value": null}]}
        }
      },
      "gridPos": {"h": 5, "w": 4, "x": 12, "y": 0},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"binary_sensor.jean_luc_plug_value\"}",
          "refId": "A"
        }
      ],
      "title": "Plug",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "dark-purple", "index": 0, "text": "Idle"}}, "type": "value"},
            {"options": {"1": {"color": "yellow", "index": 1, "text": "Charging"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "transparent", "value": null}]}
        }
      },
      "gridPos": {"h": 5, "w": 4, "x": 16, "y": 0},
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"binary_sensor.jean_luc_charging_value\"}",
          "refId": "A"
        }
      ],
      "title": "Charging",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Target charge level set on the car.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 100,
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "percent"
        }
      },
      "gridPos": {"h": 5, "w": 4, "x": 20, "y": 0},
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"number.jean_luc_target_charge_level_value\"}",
          "refId": "A"
        }
      ],
      "title": "Target SoC",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "id": 7,
      "options": {
        "legend": {"calcs": ["mean", "min", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"sensor.jean_luc_battery_value\"}",
          "legendFormat": "SoC %",
          "refId": "A"
        }
      ],
      "title": "Battery SoC over time",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "lengthkm",
          "min": 0
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "id": 8,
      "options": {
        "legend": {"calcs": ["mean", "min", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"sensor.jean_luc_battery_autonomy_value\"}",
          "legendFormat": "Range",
          "refId": "A"
        }
      ],
      "title": "Estimated range over time",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "always",
            "spanNulls": true
          },
          "unit": "kwatt",
          "min": 0
        }
      },
      "description": "Empty until the car next charges — Renault only reports admissible_charging_power while a charge cable is connected.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 14},
      "id": 9,
      "options": {
        "legend": {"calcs": ["max", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"sensor.jean_luc_admissible_charging_power_value\"}",
          "legendFormat": "Admissible charging power",
          "refId": "A"
        }
      ],
      "title": "Charging power profile",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "celsius"
        }
      },
      "description": "Empty until the car is next active — these are only reported by the Renault API when the vehicle wakes up (driving, charging, or recently used).",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 14},
      "id": 10,
      "options": {
        "legend": {"calcs": ["mean", "min", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"sensor.jean_luc_battery_temperature_value\"}",
          "legendFormat": "Battery temp",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"sensor.jean_luc_outside_temperature_value\"}",
          "legendFormat": "Outside temp",
          "refId": "B"
        }
      ],
      "title": "Battery & outside temperature",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Snapshot of usable battery capacity each time SoC reaches 100%. Sparse by design — one point per full charge. Slope = degradation rate.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "points",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 8,
            "showPoints": "always",
            "spanNulls": false
          },
          "unit": "kwatth"
        }
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 23},
      "id": 11,
      "options": {
        "legend": {"calcs": ["max", "min", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "{__name__=\"sensor.jean_luc_capacity_at_full_value\"}",
          "legendFormat": "Capacity at full charge",
          "refId": "A"
        }
      ],
      "title": "Battery degradation (capacity at 100% SoC)",
      "type": "timeseries"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["car", "renault", "jean-luc", "ev"],
  "templating": {"list": []},
  "time": {"from": "now-7d", "to": "now"},
  "timepicker": {},
